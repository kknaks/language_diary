# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/language_diary

# OpenAI
OPENAI_API_KEY=sk-xxx

# ElevenLabs (STT/TTS)
ELEVENLABS_API_KEY=xxx
ELEVENLABS_AGENT_ID=대시보드에서_복사한_에이전트ID

# Azure Speech (발음 평가)
AZURE_SPEECH_KEY=xxx
AZURE_SPEECH_REGION=koreacentral

# App
SECRET_KEY=change-me-in-production
DEBUG=true

# CORS — comma-separated origins. Use "*" for dev only.
ALLOWED_ORIGINS=*

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# JWT (Phase 2)
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256

# Social Login (Phase 2)
# Google OAuth Client ID (Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# Apple Sign In (Apple Developer에서 발급)
APPLE_CLIENT_ID=com.kknaks.languagediary
APPLE_TEAM_ID=xxx
