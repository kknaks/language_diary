{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:8000",
        "EXPO_PUBLIC_WS_BASE_URL": "ws://localhost:8000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.languagediary.app",
        "EXPO_PUBLIC_WS_BASE_URL": "wss://api.languagediary.app"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.languagediary.app",
        "EXPO_PUBLIC_WS_BASE_URL": "wss://api.languagediary.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
