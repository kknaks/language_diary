# Language Diary - Environment Variables
# Copy this file to .env and fill in your values.
# For production builds, copy .env.prod to .env before building.
#
# All EXPO_PUBLIC_ vars are inlined at build time by Metro bundler.
# Run: npx expo run:ios (reads .env automatically)

# 백엔드 API 서버 주소
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# WebSocket 서버 주소
EXPO_PUBLIC_WS_BASE_URL=ws://localhost:8000
